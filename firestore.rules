
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Rules for 'attendance' collection
    match /attendance/{attId} {
      allow read, write: if false;
    }

    // Rules for 'marks' collection
    match /marks/{markId} {
      allow read, write: if false;
    }

    // Rules for 'timetable' collection
    match /timetable/{ttId} {
      allow read: if true;
      allow write: if false;
    }

    // Rules for 'notices' collection
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if request.auth != null; // Allow authenticated users to create
      allow update, delete: if false;
    }

    // Rules for 'applications' collection
    match /applications/{appId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Rules for 'documents' collection
    match /documents/{docId} {
      allow read: if true;
      allow create: if request.auth != null; // Allow authenticated users to create
      allow update, delete: if false;
    }

    // Rules for 'events' collection
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
