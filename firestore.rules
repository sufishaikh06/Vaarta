rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Rules for the 'users' collection ---
    match /users/{userId} {
      // Allow anyone to create a user (Sign Up)
      allow create: if true;

      // A logged-in user can read or update ONLY their own document
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }

    // --- Rules for other collections ---

    // Allow a logged-in user to create an application only for themselves.
    match /applications/{appId} {
      allow create: if request.auth != null 
        && request.resource.data.student_id == request.auth.uid;
    }

    // Public read access for general college info
    match /timetable/{doc} {
      allow read: if true;
    }
    match /documents/{doc} {
      allow read: if true;
    }
    match /notices/{doc} {
      allow read: if true;
    }
  }
}
