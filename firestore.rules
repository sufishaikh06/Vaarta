rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId);
    }
    
    // Rules for 'applications' collection
    match /applications/{appId} {
      allow read: if isSignedIn();
      allow create; // Allow any client to create for the prototype's chatbot
      allow update: if true; // Allow the Cloud Function (admin) to update the status
      allow delete: if false;
    }

    // Rules for other collections (read-only for authenticated users)
    match /{document=**} {
       allow read: if isSignedIn();
       allow write: if false; // Default deny all other writes
    }
  }
}
