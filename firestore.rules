rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Rules for the 'users' collection ---

    // These rules apply to the entire collection (for queries and creating new documents)
    match /users/{document=**} {
      // Allow anyone to create a user (Sign Up) and query the collection (Login)
      allow create, list: if true;
    }

    // These rules apply to a specific user document
    match /users/{userId} {
      // A logged-in user can only read or update their OWN document.
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }

    // --- Rules for other collections ---

    // Allow a logged-in user to create an application only for themselves.
    match /applications/{appId} {
      allow create: if request.auth != null && request.resource.data.student_id == request.auth.uid;
    }
    
    // Public read access for general college info
    match /timetable/{doc} {
      allow read: if true;
    }
    match /documents/{doc} {
      allow read: if true;
    }
    match /notices/{doc} {
      allow read: if true;
    }
  }
}
