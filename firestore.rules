
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Temporarily open rules for presentation
    match /users/{userId} {
      allow read, write: if true;
    }

    match /users/{document=**} {
      allow read, write: if true;
    }

    // Rules for the 'applications' collection
    match /applications/{appId} {
      // Only allow a logged-in user to create an application for themselves
      allow create: if request.auth != null && request.resource.data.student_id == request.auth.uid;
      allow read, update, delete: if request.auth != null;
    }
    
    // Default-deny all other top-level collections
    match /attendance/{document=**} {
      allow read, write: if false;
    }
    match /marks/{document=**} {
      allow read, write: if false;
    }
    match /timetable/{document=**} {
      allow read, write: if false;
    }
    match /notices/{document=**} {
      allow read, write: if false;
    }
    match /documents/{document=**} {
      allow read, write: if false;
    }
     match /events/{document=**} {
      allow read, write: if false;
    }
  }
}
