rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow anyone to read user data (e.g., for login to check if a user exists)
      allow read: if true;
      // Disallow clients from writing to the users collection directly
      allow write: if false;
    }

    // Rules for the 'applications' collection
    match /applications/{applicationId} {
      // Allow a user to create an application if they are logged in
      allow create: if request.auth != null;
      
      // Do not allow clients to read, update, or delete applications directly
      allow read, update, delete: if false;
    }

    // Default-deny for any other collections not explicitly matched
  }
}
