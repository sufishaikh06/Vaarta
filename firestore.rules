
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection:
    // Allow anyone to query the users collection to check for existing users during login.
    // Deny all write operations from the client.
    match /users/{userId} {
      allow list: if true; // Allow querying users for login
      allow get: if request.auth != null; // Allow fetching a specific user if logged in
      allow write: if false; // Deny all client-side writes
    }

    // Applications Collection:
    // Allow authenticated users to create an application, but only if the student_id
    // in the document matches their own user ID. Deny all other operations.
    match /applications/{appId} {
      allow create: if request.auth != null && request.resource.data.student_id == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Default deny for all other collections.
    // This is a security best practice.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
