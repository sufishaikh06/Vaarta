rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the 'users' collection as a whole
    match /users/{document=**} {
      // Allow anyone to create a user document (for Sign Up)
      allow create: if true;
      
      // Allow anyone to query the users collection (for Login)
      allow list: if true;
    }

    // Rules for a specific user document
    match /users/{userId} {
      // Only allow a user to read or update their OWN document
      // Note: request.auth.uid will be null for unauthenticated users,
      // so this rule correctly protects user data.
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'applications' collection
    match /applications/{appId} {
      // A user must be logged in to create an application
      // The application's student_id must match the logged-in user's ID.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.student_id;
    }

    // Implicitly deny all other operations on all other collections.
  }
}
