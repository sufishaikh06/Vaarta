rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read on users for login verification.
    // Deny all writes from the client.
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Allow authenticated users to create new applications.
    // Deny read, update, delete from the client for security.
    match /applications/{applicationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Explicitly deny access to all other collections by default.
    // This is more of a comment as default behavior is to deny.
    // match /{document=**} {
    //  allow read, write: if false;
    // }
  }
}
