rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only read their own data, but anyone can query the collection to log in.
    match /users/{userId} {
      allow read;
      allow write: if false; // Nobody can write to the user profile directly for now
    }
    
    // Students can create applications.
    // Students can read their own applications.
    // Faculty can read applications submitted to them.
    match /applications/{appId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.student_id == request.auth.uid || resource.data.faculty_id == request.auth.uid);
      allow update, delete: if false; // Nobody can update or delete for now
    }

    // Allow reading documents and notices for display on dashboards
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'faculty';
    }
    
    match /notices/{noticeId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.token.role == 'faculty';
    }

    // Allow reading timetable, attendance, and marks for dashboards
    match /timetable/{ttId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    match /attendance/{attId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    match /marks/{markId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
