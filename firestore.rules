
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny all access to collections not explicitly defined.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Specific Collection Rules ---

    // USERS: Allow public read for login, but no client-side writes.
    match /users/{userId} {
      allow read: if true;
      allow write: if false; // All writes should be handled by secure backend logic.
    }

    // APPLICATIONS: Allow authenticated users to create. Deny all other client actions.
    match /applications/{applicationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ATTENDANCE: Deny all client access.
    match /attendance/{attendanceId} {
        allow read, write: if false;
    }
    
    // MARKS: Deny all client access.
    match /marks/{markId} {
        allow read, write: if false;
    }

    // NOTICES: Deny all client access.
    match /notices/{noticeId} {
        allow read, write: if false;
    }
    
    // DOCUMENTS: Deny all client access.
    match /documents/{documentId} {
        allow read, write: if false;
    }

    // TIMETABLE: Deny all client access.
    match /timetable/{timetableId} {
        allow read, write: if false;
    }
    
    // EVENTS: Deny all client access.
    match /events/{eventId} {
        allow read, write: if false;
    }
  }
}
