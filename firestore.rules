rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStudent() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isFaculty() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
    }

    function isParent() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent';
    }
    
    function isChild(studentId) {
      let parentData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return parentData.child_id == studentId;
    }

    // Users: Can read their own profile. Can create a profile.
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        (isParent() && isChild(userId)) ||
        isFaculty()
      );
      allow create: if !isSignedIn(); // Allow user creation during signup
      allow update: if request.auth.uid == userId;
    }

    // Attendance: Students can read their own. Parents can read their child's. Faculty can read/write.
    match /attendance/{attId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/attendance/$(attId)).data.student_id == request.auth.uid ||
        (isParent() && isChild(get(/databases/$(database)/documents/attendance/$(attId)).data.student_id)) ||
        isFaculty()
      );
      allow write: if isFaculty();
    }

    // Marks: Students can read their own. Parents can read their child's. Faculty can read/write.
    match /marks/{markId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/marks/$(markId)).data.student_id == request.auth.uid ||
        (isParent() && isChild(get(/databases/$(database)/documents/marks/$(markId)).data.student_id)) ||
        isFaculty()
      );
      allow write: if isFaculty();
    }
    
    // Applications: Students can create/read their own. Faculty can read/update assigned ones.
    match /applications/{appId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/applications/$(appId)).data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/applications/$(appId)).data.faculty_id == request.auth.uid
      );
      allow create: if isStudent();
      allow update: if isFaculty(); // Faculty can update status
    }

    // Notices, Timetable, Documents, Events: Read-only for all signed-in users, writable by faculty.
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isFaculty();
    }
    
    match /timetable/{ttId} {
      allow read: if isSignedIn();
      allow write: if isFaculty();
    }

    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isFaculty();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isFaculty();
    }
  }
}
