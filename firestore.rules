rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Collection: users
    // Allow anyone to read user data (for login checks).
    // Disallow writing from the client-side for security.
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Collection: applications
    // Allow any signed-in user to create an application.
    // The Cloud Function will handle reading. Deny client-side updates/deletes.
    match /applications/{appId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Collection: attendance
    // Secure by default. No client-side access.
    match /attendance/{attId} {
      allow read, write: if false;
    }

    // Collection: marks
    // Secure by default. No client-side access.
    match /marks/{markId} {
      allow read, write: if false;
    }

    // Collection: timetable
    // Allow any client to read the timetable.
    // Disallow writing from the client.
    match /timetable/{ttId} {
      allow read: if true;
      allow write: if false;
    }

    // Collection: notices
    // Allow any client to read notices.
    // Only allow signed-in users (faculty) to create notices.
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Collection: documents
    // Allow any client to read document info.
    // Only allow signed-in users (faculty) to create documents.
    match /documents/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Collection: events
    // Allow any client to read events.
    // Disallow writing from the client.
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
