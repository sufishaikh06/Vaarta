rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read for user profiles for login verification
    match /users/{userId} {
      allow read: if true;
      allow write: if false; // Prevent client-side modification of user profiles
    }

    // Allow logged-in users to create applications
    match /applications/{appId} {
      allow create: if request.auth != null;
      // Other operations (read, update, delete) are denied from the client
      allow read, update, delete: if false;
    }
    
    // Allow public read for notices, documents, events, and timetable
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if false;
    }
    match /documents/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
    match /timetable/{entryId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny access to attendance and marks from client side
    match /attendance/{attId} {
      allow read, write: if false;
    }
    match /marks/{markId} {
      allow read, write: if false;
    }
  }
}
