rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny all reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow public read for user profiles for login, but no writes
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Allow authenticated users to create new applications
    match /applications/{applicationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    
    // The rules below are secure by default (no access) but are here as placeholders
    match /attendance/{attendanceId} {
      allow read, write: if false;
    }
    match /marks/{markId} {
      allow read, write: if false;
    }
    match /timetable/{timetableId} {
      allow read: if true; // Timetable can be public
      allow write: if false;
    }
    match /notices/{noticeId} {
      allow read: if true; // Notices can be public
      allow write: if false;
    }
    match /documents/{documentId} {
      allow read: if true; // Documents can be public
      allow write: if false;
    }
    match /events/{eventId} {
      allow read: if true; // Events can be public
      allow write: if false;
    }
  }
}
