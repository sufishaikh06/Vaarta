rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default Deny: By default, no one can read or write to any collection.
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection:
    // - Anyone can create a new user account (for signup).
    // - Anyone can query the collection (for login verification).
    // - A logged-in user can only get their OWN document.
    match /users/{userId} {
      allow create, list: if true;
      allow get: if request.auth != null && request.auth.uid == userId;
    }

    // Applications Collection:
    // - A logged-in user can only create an application for themselves.
    match /applications/{appId} {
      allow create: if request.auth != null && request.resource.data.student_id == request.auth.uid;
    }
    
    // Allow read access for other collections as needed for the dashboards
    match /attendance/{attId} {
      allow read: if request.auth != null;
    }
    match /marks/{markId} {
      allow read: if request.auth != null;
    }
    match /timetable/{ttId} {
      allow read: if request.auth != null;
    }
    match /notices/{noticeId} {
      allow read, create: if request.auth != null;
    }
    match /documents/{docId} {
      allow read, create: if request.auth != null;
    }
    match /events/{eventId} {
      allow read: if request.auth != null;
    }
  }
}
