
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS: Allow public read for login verification, but no writing.
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // APPLICATIONS: Allow a user to create an application only for themselves.
    // No one can read, update, or delete from the client.
    match /applications/{appId} {
      allow create: if request.auth != null && request.resource.data.student_id == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
